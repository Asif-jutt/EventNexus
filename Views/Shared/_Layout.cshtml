<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - EventNexus</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="flex flex-col min-h-screen bg-gray-50 pt-24">
    <header>
        <nav class="bg-white shadow-md fixed top-0 left-0 w-full z-50">
            <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">

                <h1 class="text-2xl font-bold text-blue-600">
                    EventNexus
                </h1>

                <div class="flex items-center space-x-6">

                    <a href="/" class="text-gray-600 hover:text-blue-600 font-medium">
                        Home
                    </a>

                    <a href="/Manager/Events" class="text-gray-600 hover:text-blue-600 font-medium">
                        Events
                    </a>

                    <a href="#" class="text-gray-600 hover:text-blue-600 font-medium">
                        Contact
                    </a>
                    @{
                        var user = Context.Session.GetString("Email"); 
                        if (string.IsNullOrEmpty(user))
                        {
                            <a asp-controller="Login" asp-action="Login"
                               class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
                                Login
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Login" asp-action="Logout"
                               class="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
                                Logout
                            </a>
                        }
                    }

                    

                </div>

            </div>
        </nav>
    </header>
    <main role="main" class="flex-grow max-w-7xl mx-auto px-6 pb-6">
        @RenderBody()
    </main>

    <footer class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white py-10">
        <div class="max-w-7xl mx-auto px-6 text-center">
            <h2 class="text-2xl font-bold mb-2">EventNexus</h2>

            <p class="text-sm text-blue-100 mb-6">
                Organizing events made simple, smart, and powerful.
            </p>

            <div class="flex justify-center flex-wrap gap-6 mb-6">
                <a asp-controller="Home" asp-action="Privacy" class="text-blue-100 hover:text-white">Privacy</a>
                <a asp-controller="Home" asp-action="Terms" class="text-blue-100 hover:text-white">Terms</a>
                <a asp-controller="Home" asp-action="Contact" class="text-blue-100 hover:text-white">Contact</a>
            </div>

            <div class="border-t border-white/20 my-4"></div>

            <p class="text-xs text-blue-100">
                © 2026 EventNexus. All rights reserved.
            </p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
