@model IEnumerable<EventNexus.Models.Event>

@{
    ViewData["Title"] = "All Events";
}

<div class="min-h-screen bg-gray-50 py-10 px-6">

    <div class="max-w-7xl mx-auto">

        <!-- HEADER -->
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold text-gray-900">All Events</h1>

            <a href="/Manager/CreateEvent"
               class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-xl shadow">
                + Create Event
            </a>
        </div>

        <!-- TABLE -->
        <div class="bg-white shadow rounded-2xl overflow-hidden">

            <table class="w-full text-left">

                <thead class="bg-gray-100 text-gray-700 uppercase text-sm">
                    <tr>
                        <th class="p-4">Title</th>
                        <th class="p-4">Date</th>
                        <th class="p-4">Venue</th>
                        <th class="p-4">Location</th>
                        <th class="p-4">Status</th>
                        <th class="p-4 text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr class="border-t hover:bg-gray-50">

                            <td class="p-4 font-medium">
                                @item.Title
                            </td>

                            <td class="p-4">
                                @(item.EventDate.HasValue? item.EventDate.Value.ToString("yyyy-MM-dd HH:mm") : "N/A")
                            </td>

                            <td class="p-4">
                                @item.Venue?.Name
                            </td>

                            <td class="p-4">
                                @item.Venue?.Location
                            </td>

                            <td class="p-4">
                                @if (item.Status == "Active")
                                {
                                    <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">Active</span>
                                }
                                else if (item.Status == "Draft")
                                {
                                    <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs">Draft</span>
                                }
                                else
                                {
                                    <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs">
                                        @item.Status
                                    </span>
                                }
                            </td>

                            <td class="p-4 text-center space-x-2">

                                <button onclick="viewEvent(@item.EventId)"
                                        class="px-3 py-1 bg-blue-500 text-white rounded">
                                    View
                                </button>

                                <a href="/Manager/Edit/@item.EventId"
                                   class="bg-yellow-500 hover:bg-yellow-600 text-white px-3 py-1 rounded">
                                    Edit
                                </a>

                                <a href="/Manager/QR/@item.EventId"
                                   class="bg-purple-500 hover:bg-purple-600 text-white px-3 py-1 rounded">
                                    QR
                                </a>

                                <a href="/Manager/Delete/@item.EventId"
                                   class="bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded"
                                   onclick="return confirm('Are you sure?')">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>
</div>