@model EventNexus.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<div class="min-h-screen bg-gray-50 py-12 px-4">
    <div class="max-w-5xl mx-auto">

        <h1 class="text-3xl font-extrabold text-gray-900 mb-6">Create Event</h1>

        <form asp-action="CreateEvent" asp-controller="Manager" method="post">
            @Html.AntiForgeryToken()

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

                <!-- LEFT SIDE (Event Info) -->
                <div class="lg:col-span-2 space-y-6">
                    <div class="bg-white p-8 rounded-2xl shadow border space-y-6">

                        <div>
                            <label asp-for="Title" class="block text-sm font-semibold mb-2">Event Title</label>
                            <input asp-for="Title" placeholder="Tech Conference 2026"
                                   class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                            <span asp-validation-for="Title" class="text-red-500 text-xs"></span>
                        </div>

                        <div>
                            <label asp-for="Description" class="block text-sm font-semibold mb-2">Description</label>
                            <textarea asp-for="Description" rows="5"
                                      class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
                        </div>

                        <div>
                            <label asp-for="EventDate" class="block text-sm font-semibold mb-2">Date & Time</label>
                            <input asp-for="EventDate" type="datetime-local"
                                   class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                        </div>

                        <div>
                            <label asp-for="Status" class="block text-sm font-semibold mb-2">Status</label>
                            <select asp-for="Status"
                                    class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-blue-500">
                                <option value="Active">Active</option>
                                <option value="Draft">Draft</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>

                    </div>
                </div>

                <!-- RIGHT SIDE (Venue Info) -->
                <div class="space-y-6">
                    <div class="bg-white p-6 rounded-2xl shadow border space-y-5">

                        <h3 class="font-bold text-lg">Venue Details</h3>

                        <div>
                            <label class="text-sm font-semibold mb-2 block">Venue Name</label>
                            <input name="Name" placeholder="Main Hall"
                                   class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
                        </div>

                        <div>
                            <label class="text-sm font-semibold mb-2 block">Location</label>
                            <input name="Location" placeholder="Block A"
                                   class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
                        </div>

                        <div>
                            <label class="text-sm font-semibold mb-2 block">Capacity</label>
                            <input name="Capacity" type="number" placeholder="200"
                                   class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
                        </div>

                        <hr />

                        <button type="submit"
                                class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-xl font-bold shadow">
                            Create Event
                        </button>

                        <a href="/Manager/ManagerDashboard"
                           class="block text-center bg-gray-100 hover:bg-gray-200 py-3 rounded-xl">
                            Cancel
                        </a>

                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}